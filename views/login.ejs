<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>YouTunnel — Access</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="login-body">
  <div class="login-bg">
    <div class="tunnel-lines"></div>
    <div class="login-wrap">
      <div class="login-logo">
        <div class="logo-icon">⬡</div>
        <h1>YouTunnel</h1>
        <p class="login-sub">Private Secure Channel</p>
      </div>

      <% if (error) { %>
        <div class="alert-error"><%= error %></div>
      <% } %>

      <form class="login-form" action="/login" method="POST" id="loginForm">
        <div class="field-wrap">
          <label>Username</label>
          <input type="text" name="username" placeholder="Enter username" required autocomplete="off"/>
        </div>
        <div class="field-wrap">
          <label>Password</label>
          <input type="password" name="password" placeholder="Enter password" required/>
        </div>
        <div class="field-wrap">
          <label>Server Key</label>
          <input type="text" name="serverKey" placeholder="Enter server / secret key" required autocomplete="off"/>
        </div>
        <button type="submit" class="btn-login" id="loginBtn">
          <span class="btn-text">Access Tunnel</span>
          <span class="btn-loader" style="display:none">
            <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          </span>
        </button>
      </form>

      <p class="login-footer">Unauthorized access is prohibited. All activity is logged.</p>
    </div>
  </div>

  <script>
    document.getElementById('loginForm').addEventListener('submit', function() {
      document.querySelector('.btn-text').style.display = 'none';
      document.querySelector('.btn-loader').style.display = 'inline-flex';
      document.getElementById('loginBtn').disabled = true;
    });
  </script>
</body>
</html>
